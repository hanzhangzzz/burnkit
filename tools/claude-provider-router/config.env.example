# Claude Code 模型配置
# 复制为 config.env 后填入真实值：cp config.env.example config.env

# COMPACT_WINDOW: compact 触发阈值（tokens），不填则使用默认值 ~150K
# 200K 模型建议设 150000，1M 模型建议设 750000

# 配置 0 - MiniMax
CONFIG_0_BASE_URL=https://api.minimaxi.com/anthropic
CONFIG_0_AUTH_TOKEN=your-minimax-token-here
CONFIG_0_COMPACT_WINDOW=150000
CONFIG_0_MODEL=MiniMax-M2.7-highspeed

# 配置 1 - DeepSeek V4 Pro
CONFIG_1_BASE_URL=https://api.deepseek.example.com/anthropic
CONFIG_1_AUTH_TOKEN=your-deepseek-token-here
CONFIG_1_COMPACT_WINDOW=150000
CONFIG_1_MODEL=deepseek-v4-pro[1m]

# 配置 2 - GLM
CONFIG_2_BASE_URL=https://api.z.ai/api/anthropic
CONFIG_2_AUTH_TOKEN=your-zai-token-here
CONFIG_2_COMPACT_WINDOW=150000
CONFIG_2_MODEL=glm-5.1

# 配置 3 - AWS Claude Sonnet 4.5 代理
CONFIG_3_BASE_URL=https://your-proxy.example.com/proxy/aws-claude-sonnet-4-5
CONFIG_3_AUTH_TOKEN=your-proxy-token-here
CONFIG_3_COMPACT_WINDOW=150000

# 配置 4 - AWS Claude Opus 4.6 代理
CONFIG_4_BASE_URL=https://your-proxy.example.com/proxy/aws-claude-opus-4-6
CONFIG_4_AUTH_TOKEN=your-proxy-token-here
CONFIG_4_COMPACT_WINDOW=750000

# 配置 5 - GLM-5 代理
CONFIG_5_BASE_URL=https://your-proxy.example.com/proxy/kivy-glm-5
CONFIG_5_AUTH_TOKEN=your-proxy-token-here
CONFIG_5_COMPACT_WINDOW=150000

# 配置 6 - AWS Claude Sonnet 4.6 代理
CONFIG_6_BASE_URL=https://your-proxy.example.com/proxy/aws-claude-sonnet-4-6
CONFIG_6_AUTH_TOKEN=your-proxy-token-here
CONFIG_6_COMPACT_WINDOW=750000

# 配置 7 - AWS Claude Opus 4.7 代理
CONFIG_7_BASE_URL=https://your-proxy.example.com/proxy/aws-claude-opus-4-7
CONFIG_7_AUTH_TOKEN=your-proxy-token-here
CONFIG_7_COMPACT_WINDOW=750000
