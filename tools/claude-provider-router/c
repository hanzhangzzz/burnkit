#!/bin/bash
#
# c - Claude Code 模型切换器
# 用法:
#   c [编号] [额外参数...]          # 单 provider 模式
#   c team [leader编号] [teammate编号] [额外参数...]  # team 模式，双 provider 路由
#   c s                             # 显示配置文件
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/config.env"
ROUTER_SCRIPT="${SCRIPT_DIR}/router.py"
C_SETTINGS="$HOME/.claude/settings-c.json"
ROUTER_PID_DIR="${SCRIPT_DIR}/.routers"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# 错误退出
die() {
    echo -e "${RED}错误: $1${NC}" >&2
    exit 1
}

# 检查配置文件是否存在
check_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo -e "${YELLOW}配置文件不存在，正在创建模板...${NC}"
        mkdir -p "$(dirname "$CONFIG_FILE")"
        cat > "$CONFIG_FILE" << 'EOF'
# Claude Code 模型配置
# 格式: CONFIG_编号_BASE_URL 和 CONFIG_编号_AUTH_TOKEN

# 配置 1 - 极速模型 (Haiku)
CONFIG_1_BASE_URL=https://api.example.com/v1
CONFIG_1_AUTH_TOKEN=your-token-here

# 配置 2 - 均衡模型 (Sonnet)
CONFIG_2_BASE_URL=https://api.example.com/v1
CONFIG_2_AUTH_TOKEN=your-token-here

# 配置 3 - 最强模型 (Opus)
CONFIG_3_BASE_URL=https://api.anthropic.com
CONFIG_3_AUTH_TOKEN=your-token-here

# 可选配置项:
# CONFIG_X_COMPACT_WINDOW=750000  # compact 触发阈值（tokens）
# CONFIG_X_MODEL=MiniMax-M2.7     # 强制指定模型名
# CONFIG_X_EFFORT=max             # 思考深度: minimal/low/medium/high/max
EOF
        chmod 600 "$CONFIG_FILE"
        echo -e "${GREEN}已创建模板: $CONFIG_FILE${NC}"
        echo -e "${YELLOW}请编辑配置文件后重试${NC}"
        exit 0
    fi
}

# 从 config.env 读取某个 config 的字段
read_config_field() {
    local num="$1"
    local field="$2"
    grep "^CONFIG_${num}_${field}=" "$CONFIG_FILE" | cut -d'=' -f2-
}

# 显示帮助信息
show_help() {
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  c - Claude Code 模型切换器${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "用法:"
    echo -e "  ${GREEN}c [编号] [额外参数...]${NC}                     单 provider 模式"
    echo -e "  ${GREEN}c team [leader编号] [teammate编号] [参数...]${NC}  team 路由模式"
    echo -e "  ${GREEN}c s${NC}                                        显示完整配置文件"
    echo -e "  ${GREEN}c router stop${NC}                              停止路由代理"
    echo ""
    echo "可用配置:"

    if [[ -f "$CONFIG_FILE" ]]; then
        local numbers=$(grep -oE "CONFIG_[0-9]+_BASE_URL" "$CONFIG_FILE" | grep -oE "[0-9]+" | sort -u)
        for num in $numbers; do
            local base_url=$(read_config_field "$num" "BASE_URL")
            local model=$(read_config_field "$num" "MODEL")
            if [[ -n "$base_url" ]]; then
                local label="${model:-${base_url##*/}}"
                echo -e "  ${GREEN}$num${NC} → ${label} (${base_url})"
            fi
        done
    else
        echo -e "  ${YELLOW}配置文件不存在${NC}"
    fi

    echo ""
    echo "示例:"
    echo -e "  ${GREEN}c 6${NC}           # 使用配置 6 启动"
    echo -e "  ${GREEN}c 6 --resume${NC}  # 使用配置 6 并恢复上次会话"
    echo -e "  ${GREEN}c team 7 0${NC}    # team lead 用配置 7，teammate 用配置 0"
    echo -e "  ${GREEN}c team 4 0 --resume${NC}"
    echo ""
    echo -e "team 模式路由规则:"
    echo -e "  基于 auth token 自动区分 leader/teammate"
    echo -e "  leader 请求 → leader provider，teammate 请求 → teammate provider"
    echo ""
}

# ──────────────────────────────────────────
# 路由代理管理
# ──────────────────────────────────────────

# 找一个空闲端口（从 3100 开始往上找）
find_free_port() {
    local port=3100
    while lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null; do
        (( port++ ))
    done
    echo "$port"
}

# 列出所有存活的路由代理实例
router_list_alive() {
    mkdir -p "$ROUTER_PID_DIR"
    for f in "$ROUTER_PID_DIR"/*.pid; do
        [[ -f "$f" ]] || continue
        local pid port
        pid=$(cat "$f")
        port="${f##*/}"
        port="${port%.pid}"
        if kill -0 "$pid" 2>/dev/null; then
            echo "$port $pid"
        else
            rm -f "$f"
        fi
    done
}

router_stop_all() {
    local found=0
    while read -r port pid; do
        kill "$pid" 2>/dev/null
        rm -f "${ROUTER_PID_DIR}/${port}.pid"
        echo -e "${YELLOW}路由代理已停止 (port=$port pid=$pid)${NC}"
        found=1
    done < <(router_list_alive)
    [[ $found -eq 0 ]] && echo -e "${YELLOW}没有运行中的路由代理${NC}"
}

router_start() {
    local leader_url="$1"
    local leader_token="$2"
    local teammate_url="$3"
    local teammate_token="$4"

    [[ ! -f "$ROUTER_SCRIPT" ]] && die "router.py 未找到: $ROUTER_SCRIPT"

    mkdir -p "$ROUTER_PID_DIR"

    # 每次分配新端口，互不干扰
    local port
    port=$(find_free_port)
    local log_file="${ROUTER_PID_DIR}/${port}.log"

    ROUTER_LEADER_URL="$leader_url" \
    ROUTER_LEADER_TOKEN="$leader_token" \
    ROUTER_TEAMMATE_URL="$teammate_url" \
    ROUTER_TEAMMATE_TOKEN="$teammate_token" \
    ROUTER_TEAMMATE_MODEL="$teammate_model" \
    uvicorn router:app \
        --app-dir "$SCRIPT_DIR" \
        --host 127.0.0.1 \
        --port "$port" \
        --log-level info \
        > "$log_file" 2>&1 &

    local pid=$!
    echo "$pid" > "${ROUTER_PID_DIR}/${port}.pid"

    # 等待代理就绪（最多 5 秒）
    local max_wait=50 waited=0
    while [[ $waited -lt $max_wait ]]; do
        if curl -sf "http://127.0.0.1:${port}/" > /dev/null 2>&1; then
            # 把端口暴露给调用方
            ROUTER_ALLOCATED_PORT="$port"
            return 0
        fi
        sleep 0.1
        (( waited++ ))
    done

    echo -e "${RED}路由代理启动超时，日志如下:${NC}"
    cat "$log_file"
    die "路由代理启动失败"
}

# ──────────────────────────────────────────
# 单 provider 启动
# ──────────────────────────────────────────

start_single() {
    local config_num="$1"
    shift

    check_config

    local base_url
    local auth_token
    local compact_window
    local model
    local effort

    base_url=$(read_config_field "$config_num" "BASE_URL")
    auth_token=$(read_config_field "$config_num" "AUTH_TOKEN")
    compact_window=$(read_config_field "$config_num" "COMPACT_WINDOW")
    model=$(read_config_field "$config_num" "MODEL")
    effort=$(read_config_field "$config_num" "EFFORT")

    [[ -z "$base_url" ]]    && die "配置 $config_num 的 BASE_URL 未找到"
    [[ -z "$auth_token" ]]  && die "配置 $config_num 的 AUTH_TOKEN 未找到"

    local model_name="${model:-${base_url##*/}}"

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🚀 启动 Claude Code [配置 $config_num]${NC}"
    echo -e "${BLUE}   API:   $base_url${NC}"
    echo -e "${YELLOW}   模型:  $model_name${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    export ANTHROPIC_BASE_URL="$base_url"
    # 用 CLAUDE_AUTH_TOKEN 存 token，由 apiKeyHelper 读取
    # 避免 ANTHROPIC_AUTH_TOKEN 与 apiKeyHelper 冲突
    export CLAUDE_AUTH_TOKEN="$auth_token"
    unset ANTHROPIC_AUTH_TOKEN
    export CLAUDE_MODEL_LABEL="$model_name"

    if [[ -n "$model" ]]; then
        export ANTHROPIC_SMALL_FAST_MODEL="$model"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$model"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$model"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$model"
        echo -e "${YELLOW}   Model Override: $model${NC}"
    else
        unset ANTHROPIC_SMALL_FAST_MODEL
        unset ANTHROPIC_DEFAULT_SONNET_MODEL
        unset ANTHROPIC_DEFAULT_OPUS_MODEL
        unset ANTHROPIC_DEFAULT_HAIKU_MODEL
    fi

    if [[ -n "$compact_window" ]]; then
        export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$compact_window"
        echo -e "${BLUE}   Compact: ${compact_window} tokens${NC}"
    else
        unset CLAUDE_CODE_AUTO_COMPACT_WINDOW
        echo -e "${BLUE}   Compact: 默认 (~150K tokens)${NC}"
    fi

    if [[ -n "$effort" ]]; then
        export CLAUDE_CODE_EFFORT_LEVEL="$effort"
        echo -e "${MAGENTA}   Effort: ${effort}${NC}"
    else
        unset CLAUDE_CODE_EFFORT_LEVEL
    fi

    command -v claude &>/dev/null || die "claude 命令未找到"

    exec claude --dangerously-skip-permissions --settings "$C_SETTINGS" --teammate-mode tmux "$@"
}

# ──────────────────────────────────────────
# team 模式启动
# ──────────────────────────────────────────

start_team() {
    local leader_num="$1"
    local teammate_num="$2"
    shift 2

    check_config

    # 读取 leader 配置
    local leader_url leader_token leader_compact leader_model leader_effort
    leader_url=$(read_config_field "$leader_num" "BASE_URL")
    leader_token=$(read_config_field "$leader_num" "AUTH_TOKEN")
    leader_compact=$(read_config_field "$leader_num" "COMPACT_WINDOW")
    leader_model=$(read_config_field "$leader_num" "MODEL")
    leader_effort=$(read_config_field "$leader_num" "EFFORT")

    [[ -z "$leader_url" ]]   && die "leader 配置 $leader_num 的 BASE_URL 未找到"
    [[ -z "$leader_token" ]] && die "leader 配置 $leader_num 的 AUTH_TOKEN 未找到"

    # 读取 teammate 配置
    local teammate_url teammate_token teammate_model
    teammate_url=$(read_config_field "$teammate_num" "BASE_URL")
    teammate_token=$(read_config_field "$teammate_num" "AUTH_TOKEN")
    teammate_model=$(read_config_field "$teammate_num" "MODEL")

    [[ -z "$teammate_url" ]]   && die "teammate 配置 $teammate_num 的 BASE_URL 未找到"
    [[ -z "$teammate_token" ]] && die "teammate 配置 $teammate_num 的 AUTH_TOKEN 未找到"

    local leader_label="${leader_model:-${leader_url##*/}}"
    local teammate_label="${teammate_model:-${teammate_url##*/}}"

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🚀 启动 Claude Code [Team 模式]${NC}"
    echo -e "${MAGENTA}   Leader   [${leader_num}]: ${leader_label}${NC}"
    echo -e "${BLUE}             ${leader_url}${NC}"
    echo -e "${YELLOW}   Teammate [${teammate_num}]: ${teammate_label}${NC}"
    echo -e "${BLUE}             ${teammate_url}${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    # 启动路由代理（自动分配空闲端口）
    echo -e "${BLUE}▶ 启动路由代理...${NC}"
    ROUTER_ALLOCATED_PORT=""
    router_start "$leader_url" "$leader_token" "$teammate_url" "$teammate_token"
    echo -e "${GREEN}✓ 路由代理就绪 (port ${ROUTER_ALLOCATED_PORT})${NC}"
    echo ""

    # compact window 用 leader 的（team lead 是主进程）
    if [[ -n "$leader_compact" ]]; then
        export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$leader_compact"
        echo -e "${BLUE}   Compact: ${leader_compact} tokens${NC}"
    else
        unset CLAUDE_CODE_AUTO_COMPACT_WINDOW
    fi

    # effort 用 leader 的
    if [[ -n "$leader_effort" ]]; then
        export CLAUDE_CODE_EFFORT_LEVEL="$leader_effort"
        echo -e "${MAGENTA}   Effort: ${leader_effort}${NC}"
    else
        unset CLAUDE_CODE_EFFORT_LEVEL
    fi

    # 清除旧的模型 override，让路由代理完全接管
    unset ANTHROPIC_SMALL_FAST_MODEL
    unset ANTHROPIC_DEFAULT_SONNET_MODEL
    unset ANTHROPIC_DEFAULT_OPUS_MODEL
    unset ANTHROPIC_DEFAULT_HAIKU_MODEL

    export ANTHROPIC_BASE_URL="http://127.0.0.1:${ROUTER_ALLOCATED_PORT}"
    unset ANTHROPIC_AUTH_TOKEN
    # 标记 leader 身份：这个变量会被 claode 保留在主进程，spawn teammate 时被过滤掉
    # apiKeyHelper 据此返回不同 token，路由器据此区分路由
    export CLAUDE_TEAM_ROLE=leader
    export CLAUDE_MODEL_LABEL="team(${leader_label}+${teammate_label})"

    command -v claude &>/dev/null || die "claude 命令未找到"

    # 不用 exec，用普通启动 + trap，确保 claude 退出后自动关闭代理
    # 注意：cleanup 在 trap 回调时局部变量已超出作用域，用全局变量传递
    _CLEANUP_ROUTER_PORT="$ROUTER_ALLOCATED_PORT"
    _CLEANUP_ROUTER_PID=$(cat "${ROUTER_PID_DIR}/${ROUTER_ALLOCATED_PORT}.pid")

    cleanup() {
        kill "$_CLEANUP_ROUTER_PID" 2>/dev/null
        rm -f "${ROUTER_PID_DIR}/${_CLEANUP_ROUTER_PORT}.pid"
        echo -e "\n${YELLOW}路由代理已关闭 (port=${_CLEANUP_ROUTER_PORT})${NC}"
    }
    trap cleanup EXIT INT TERM

    claude --dangerously-skip-permissions --settings "$C_SETTINGS" --teammate-mode tmux "$@"
}

# ──────────────────────────────────────────
# 主逻辑
# ──────────────────────────────────────────

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    local cmd="$1"

    # c s / c show
    if [[ "$cmd" == "s" || "$cmd" == "show" ]]; then
        check_config
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${CYAN}  配置文件: ${BLUE}$CONFIG_FILE${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        cat "$CONFIG_FILE"
        exit 0
    fi

    # c router stop / status
    if [[ "$cmd" == "router" ]]; then
        local sub="${2:-}"
        if [[ "$sub" == "stop" ]]; then
            router_stop_all
        elif [[ "$sub" == "status" ]]; then
            local count=0
            while read -r port pid; do
                echo -e "${GREEN}路由代理运行中 (port=$port pid=$pid)${NC}"
                curl -sf "http://127.0.0.1:${port}/" | python3 -m json.tool 2>/dev/null
                (( count++ ))
            done < <(router_list_alive)
            [[ $count -eq 0 ]] && echo -e "${YELLOW}没有运行中的路由代理${NC}"
        else
            echo -e "用法: ${GREEN}c router stop${NC} | ${GREEN}c router status${NC}"
        fi
        exit 0
    fi

    # c team [leader] [teammate] [额外参数...]
    if [[ "$cmd" == "team" ]]; then
        [[ $# -lt 3 ]] && die "用法: c team [leader编号] [teammate编号] [额外参数...]"
        local leader_num="$2"
        local teammate_num="$3"
        shift 3
        [[ "$leader_num" =~ ^[0-9]+$ ]]   || die "leader 编号必须是数字"
        [[ "$teammate_num" =~ ^[0-9]+$ ]] || die "teammate 编号必须是数字"
        start_team "$leader_num" "$teammate_num" "$@"
        exit 0
    fi

    # c [编号] [额外参数...]
    if [[ "$cmd" =~ ^[0-9]+$ ]]; then
        shift
        start_single "$cmd" "$@"
        exit 0
    fi

    die "未知命令: $cmd\n运行 c 查看帮助"
}

main "$@"
